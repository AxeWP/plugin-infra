/**
 * Shared TypeScript base config for AxeWP plugins.
 *
 * `tsconfig.json` — set `paths`, `types`, `include` and `exclude` locally:
 *	{ "extends": "@axewp/plugin-infra/tsconfig" }
 */
{
	"$schema": "https://json.schemastore.org/tsconfig.json",

	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,

		// Type checking.
		"strict": true,
		"allowSyntheticDefaultImports": true,
		"allowUnreachableCode": false,
		"allowUnusedLabels": false,
		"exactOptionalPropertyTypes": true,
		"noErrorTruncation": true,
		"noFallthroughCasesInSwitch": true,
		"noImplicitOverride": true,
		"noImplicitReturns": true,
		"noPropertyAccessFromIndexSignature": true,
		"noUncheckedIndexedAccess": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,

		// Modules
		// `preserve` implies `moduleResolution: bundler`.
		"module": "preserve",
		"resolveJsonModule": true,

		// Interop Constraints
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"isolatedModules": true,
		"verbatimModuleSyntax": true,

		// Language and Environment
		"jsx": "react-jsx",
		"lib": [ "ES2023", "DOM.Iterable", "DOM" ],
		"moduleDetection": "force",
		"target": "ES2023",

		// Projects
		"incremental": true,

		// Completeness
		"skipLibCheck": true
	}
}
