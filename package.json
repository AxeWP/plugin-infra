{
	"name": "@axepress/plugin-infra",
	"version": "0.2.0",
	"description": "Shareable base configs for AxeWP WordPress plugins.",
	"license": "GPL-2.0-or-later",
	"homepage": "https://github.com/AxeWP/plugin-infra#readme",
	"bugs": "https://github.com/AxeWP/plugin-infra/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/AxeWP/plugin-infra.git"
	},
	"type": "module",
	"engines": {
		"node": ">=24.0.0",
		"npm": ">=11.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"configs",
		"examples",
		"README.md",
		"LICENSE.md"
	],
	"exports": {
		"./prettier": "./configs/prettier.mjs",
		"./tsconfig": "./configs/tsconfig.json",
		"./eslint": "./configs/eslint.mjs",
		"./package.json": "./package.json"
	},
	"scripts": {
		"format": "prettier --write ."
	},
	"peerDependencies": {
		"@wordpress/eslint-plugin": ">=25.0.0",
		"@wordpress/prettier-config": ">=4.0.0",
		"eslint": ">=9.0.0",
		"eslint-plugin-jest": ">=29.0.0",
		"prettier": ">=3.0.0",
		"typescript": ">=5.0.0"
	},
	"peerDependenciesMeta": {
		"@wordpress/eslint-plugin": {
			"optional": true
		},
		"@wordpress/prettier-config": {
			"optional": true
		},
		"eslint": {
			"optional": true
		},
		"eslint-plugin-jest": {
			"optional": true
		},
		"prettier": {
			"optional": true
		},
		"typescript": {
			"optional": true
		}
	},
	"devDependencies": {
		"@wordpress/eslint-plugin": "^25.7.0",
		"@wordpress/prettier-config": "^4.51.0",
		"eslint-plugin-jest": "^29.15.5",
		"lefthook": "^2.1.10",
		"lint-staged": "^17.1.0",
		"prettier": "npm:wp-prettier@^3",
		"string-argv": "^0.3.2"
	},
	"allowScripts": {
		"lefthook@2.1.10": true,
		"core-js@3.49.0": true,
		"unrs-resolver@1.12.2": true
	}
}
